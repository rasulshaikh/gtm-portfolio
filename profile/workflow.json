{
  "workflow_version": "1.0",
  "name": "GTM Signal-to-Pipeline Loop",
  "description": "End-to-end motion from signal capture through personalized outbound to content mining. Each phase maps to an open-source repo or production toolchain.",
  "loop_type": "compounding",
  "phases": [
    {
      "phase": 1,
      "label": "Capture Signal",
      "icon": "signal",
      "description": "Ingest LinkedIn engagers, funding alerts, hiring posts, tech stack changes",
      "tools": ["PhantomBuster", "HeyReach", "Trigify", "Crunchbase"],
      "repo": "gtm-founder-led-loop",
      "script": "loop/01_signal_capture.py",
      "output": "engagers.csv"
    },
    {
      "phase": 2,
      "label": "Enrich",
      "icon": "enrich",
      "description": "Apollo + Clay waterfall: firmographics, technographics, contact data",
      "tools": ["Apollo", "Clay", "Prospeo", "Firecrawl", "Deepline"],
      "repo": null,
      "script": null,
      "output": "enriched_table"
    },
    {
      "phase": 3,
      "label": "Score & Route",
      "icon": "score",
      "description": "Composite 0-100 ICP score → Hot / Warm / Nurture routing",
      "tools": ["gtm-ai-lead-scorer", "Clay formulas"],
      "repo": "gtm-ai-lead-scorer",
      "script": "loop/02_score_and_route.py",
      "output": "scored_engagers.csv"
    },
    {
      "phase": 4,
      "label": "Personalize",
      "icon": "personalize",
      "description": "MiniMax generates signal-specific hooks; Clay formulas assemble full copy",
      "tools": ["MiniMax Text-01", "gtm-cold-email-personalizer", "Clay IIFE"],
      "repo": "gtm-email-cadences",
      "script": "cadence_runner.py",
      "output": "personalized_sequences"
    },
    {
      "phase": 5,
      "label": "Send",
      "icon": "send",
      "description": "23 cadences → Smartlead / Instantly / HeyReach. Warm tier gets founder DM.",
      "tools": ["Smartlead", "Instantly", "HeyReach"],
      "repo": "gtm-founder-led-loop",
      "script": "loop/03_outbound.py",
      "output": "live_campaigns"
    },
    {
      "phase": 6,
      "label": "Mine & Loop",
      "icon": "loop",
      "description": "Extract objections, wins, questions from calls → next content post → restart",
      "tools": ["MiniMax Text-01", "reply-intent-classifier"],
      "repo": "gtm-founder-led-loop",
      "script": "loop/04_content_miner.py",
      "output": "content_angles → Phase 1"
    }
  ],
  "copy_map": [
    {
      "type": "Cold email cadences",
      "count": "23 sequences",
      "location": "github.com/rasulshaikh/gtm-email-cadences/cadences/",
      "format": "YAML",
      "ai_model": "MiniMax-Text-01 (hook only)"
    },
    {
      "type": "Clay copy formulas",
      "count": "6 IIFEs",
      "location": "github.com/rasulshaikh/gtm-clay-formula-library/formulas/",
      "format": "JavaScript",
      "ai_model": "Claygent (in-table)"
    },
    {
      "type": "Warm outbound (engager)",
      "count": "Dynamic per lead",
      "location": "github.com/rasulshaikh/gtm-founder-led-loop/loop/03_outbound.py",
      "format": "Python → CSV",
      "ai_model": "MiniMax-Text-01"
    },
    {
      "type": "Single-lead email",
      "count": "1 email per URL",
      "location": "github.com/rasulshaikh/gtm-cold-email-personalizer/",
      "format": "Python CLI",
      "ai_model": "Claude API"
    },
    {
      "type": "Lead scoring rubric",
      "count": "0-100 composite",
      "location": "github.com/rasulshaikh/gtm-ai-lead-scorer/",
      "format": "Python CSV",
      "ai_model": "Claude Haiku"
    },
    {
      "type": "Production Omnibound",
      "count": "60-col Clay workflow",
      "location": "notes/sources/gtm/ (local)",
      "format": "Clay table + Clayscript",
      "ai_model": "Claygent Neon + purple-safety"
    }
  ]
}